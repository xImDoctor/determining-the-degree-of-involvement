# Пример конфигурации для frontend.
# Скопируйте в .env и отредактируйте под свою среду:
#   cp .env.example .env
#
# Системные переменные окружения имеют приоритет над значениями из .env.

# WebSocket-адрес бэкенда (для отправки кадров)
BACKEND_WS_URL=ws://localhost:8000

# HTTP-адрес бэкенда (для health-check'а)
BACKEND_HTTP_URL=http://localhost:8000

# Порог красной пунктирной линии на графике EAR (только визуализация, на бэкенд не влияет)
EAR_THRESHOLD=0.18
